@model Employee

<h2>Edit Employee</h2>

<form asp-action="Edit" method="post" class="row g-3">
    <input type="hidden" asp-for="Id" />
    <div class="col-md-6">
        <label class="form-label">Name</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Designation</label>
        <input asp-for="Designation" class="form-control" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Department</label>
        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments"></select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Basic Salary</label>
        <input asp-for="BasicSalary" class="form-control" />
    </div>
    <div class="col-12">
        <label class="form-label">Contact Info</label>
        <input asp-for="ContactInfo" class="form-control" />
    </div>
    <div class="col-12">
        <button class="btn btn-primary" type="submit">Update</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>