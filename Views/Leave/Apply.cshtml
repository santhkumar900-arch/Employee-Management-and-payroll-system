@model EmployeeHrSystem.Models.LeaveRequest

<h2>Apply Leave</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Apply" asp-controller="Leave" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label class="form-label">Employee</label>
        <select asp-for="EmployeeId"
                class="form-select"
                asp-items="@((IEnumerable<SelectListItem>)ViewBag.EmployeeItems)">
            <option value="">-- select --</option>
        </select>
        <span asp-validation-for="EmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Start Date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">End Date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Leave Type</label>
        <select asp-for="LeaveType" class="form-select">
            <option>CASUAL</option>
            <option>SICK</option>
            <option>ANNUAL</option>
        </select>
        <span asp-validation-for="LeaveType" class="text-danger"></span>
    </div>

    @if (!User.IsInRole("Employee"))
    {
        <div class="mb-3">
            <label class="form-label">Status</label>
            <select asp-for="Status" class="form-select">
                <option>APPLIED</option>
                <option>APPROVED</option>
                <option>REJECTED</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
    }
    else
    {
        <input type="hidden" asp-for="Status" value="APPLIED" />
    }

    <button type="submit" class="btn btn-success">Apply</button>
    <a asp-action="Index" asp-controller="Leave" class="btn btn-secondary">Back</a>
</form>
