@{
    ViewData["Title"] = "Manager Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-person-workspace text-warning me-2"></i>Manager Dashboard</h2>
        <p class="text-muted mb-0">Team oversight &amp; performance management</p>
    </div>
    <span class="badge bg-warning text-dark fs-6 px-3 py-2"><i class="bi bi-person-check me-1"></i>Manager</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #f59e0b !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#fef3c7;"><i class="bi bi-calendar-check fs-3 text-warning"></i></div>
                <div><div class="text-muted small">Leave Approvals</div><div class="fw-bold fs-5">Review &amp; Approve</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #6366f1 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ede9fe;"><i class="bi bi-bar-chart-line fs-3 text-primary"></i></div>
                <div><div class="text-muted small">Performance</div><div class="fw-bold fs-5">Track Team</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #10b981 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#d1fae5;"><i class="bi bi-clock-history fs-3 text-success"></i></div>
                <div><div class="text-muted small">Attendance</div><div class="fw-bold fs-5">Monitor</div></div>
            </div>
        </div>
    </div>
</div>

<h5 class="fw-semibold mb-3 text-muted">Manager Modules</h5>
<div class="row g-3">
    @foreach (var m in new[] {
        ("Leave","Index","bi-calendar-x","warning","Leave Requests"),
        ("Attendance","Index","bi-clock-history","success","Attendance"),
        ("Performance","Index","bi-bar-chart-line","primary","Performance"),
        ("Appraisal","Index","bi-star-half","info","Appraisals"),
    })
    {
        <div class="col-md-3">
            <a asp-controller="@m.Item1" asp-action="@m.Item2"
               class="card border-0 shadow-sm text-decoration-none h-100 dashboard-card">
                <div class="card-body text-center py-4">
                    <i class="bi @m.Item3 fs-2 text-@m.Item4 mb-2 d-block"></i>
                    <div class="fw-semibold">@m.Item5</div>
                </div>
            </a>
        </div>
    }
</div>
