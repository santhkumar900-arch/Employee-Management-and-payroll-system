@{
    ViewData["Title"] = "Employee Dashboard";
}

@{
    var empName = User.Identity?.Name ?? "Employee";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-0"><i class="bi bi-person-circle text-secondary me-2"></i>Employee Dashboard</h2>
        <p class="text-muted mb-0">Welcome back, <strong>@empName</strong></p>
    </div>
    <span class="badge bg-secondary fs-6 px-3 py-2"><i class="bi bi-person me-1"></i>Employee</span>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #6366f1 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#ede9fe;"><i class="bi bi-calendar-plus fs-3 text-primary"></i></div>
                <div><div class="text-muted small">Leave Application</div><div class="fw-bold fs-5">Apply for Leave</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #10b981 !important;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background:#d1fae5;"><i class="bi bi-list-check fs-3 text-success"></i></div>
                <div><div class="text-muted small">My Leaves</div><div class="fw-bold fs-5">View Status</div></div>
            </div>
        </div>
    </div>
</div>

<h5 class="fw-semibold mb-3 text-muted">Self-Service Portal</h5>
<div class="row g-3">
    <div class="col-md-6">
        <a asp-controller="Leave" asp-action="Apply"
           class="card border-0 shadow-sm text-decoration-none h-100 dashboard-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-calendar-plus fs-2 text-primary mb-2 d-block"></i>
                <div class="fw-semibold">Apply Leave</div>
                <div class="text-muted small mt-1">Submit a new leave request</div>
            </div>
        </a>
    </div>
    <div class="col-md-6">
        <a asp-controller="Leave" asp-action="Index"
           class="card border-0 shadow-sm text-decoration-none h-100 dashboard-card">
            <div class="card-body text-center py-4">
                <i class="bi bi-list-ul fs-2 text-success mb-2 d-block"></i>
                <div class="fw-semibold">My Leave History</div>
                <div class="text-muted small mt-1">Track your leave requests</div>
            </div>
        </a>
    </div>
</div>
